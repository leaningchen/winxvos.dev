/*
 * boot/stage2.S — 第二阶段加载器
 * 链接地址: 0x10000（实模式段 0x1000:0x0000）
 *
 * 执行流程:
 *   [.code16] 实模式（DS=0x1000，段内偏移访问所有变量）:
 *     - 保存引导驱动器号（DL）→ s2_drive
 *     - E820 内存探测 → 0x6000
 *     - VBE 图形模式设置（1680x1050 → 1440x900 → 800x600）
 *     - ACPI RSDP 探测
 *     - 填写 BootInfo（0x5000）magic/version
 *     - 构建 GDT，进入 32 位保护模式
 *   [.code32] 32 位保护模式:
 *     - CPUID 长模式检查
 *     - PIO ATA（LBA28）加载内核 → 0x100000
 *     - 构建 4 级页表（Identity Map 前 4GB，2MB 大页）
 *     - 进入 64 位长模式，远跳 kernel_entry@0x100000
 *
 * KERNEL_LBA / KERNEL_SECTORS 由 Makefile 通过 --defsym 传入
 */

/* BootInfo 字段偏移 */
.equ BI_MAGIC,      0x00
.equ BI_VERSION,    0x04
.equ BI_FB_ADDR,    0x08    /* uint64 */
.equ BI_FB_PITCH,   0x10
.equ BI_FB_WIDTH,   0x14
.equ BI_FB_HEIGHT,  0x18
.equ BI_FB_BPP,     0x1C
.equ BI_E820_CNT,   0x20
.equ BI_E820_ADDR,  0x24
.equ BI_MEM_TOTAL,  0x28    /* uint64 */
.equ BI_RSDP_ADDR,  0x30    /* uint64 */
.equ BI_BOOT_DRV,   0x38
.equ BI_CPU_CNT,    0x3C

/* 固定物理地址（均 < 1MB，16位模式可用 DS=0 直接访问）*/
.equ BOOT_INFO,     0x5000
.equ E820_BUF,      0x6000
.equ VBE_INFO,      0x7000
.equ VBE_MODE,      0x7200
.equ PML4_BASE,     0x400000
.equ KENTRY,        0x100000

/* VBE ModeInfoBlock 字段偏移 */
.equ MIB_ATTR,      0x00
.equ MIB_XRES,      0x12
.equ MIB_YRES,      0x14
.equ MIB_BPP,       0x19
.equ MIB_MODEL,     0x1B
.equ MIB_BASE,      0x28
.equ MIB_PITCH,     0x31

/* 内核磁盘参数（由 Makefile --defsym 传入）*/
#ifndef KERNEL_LBA
#define KERNEL_LBA 65
#endif
#ifndef KERNEL_SECTORS
#define KERNEL_SECTORS 256
#endif

/*===========================================================================
 * 16 位实模式
 * 约定: DS=0x1000（段基 = 链接地址 0x10000）
 *   → 段内变量访问：直接用符号名（GAS 会算段内偏移）
 *   → 物理地址 < 1MB 的绝对访问：临时 DS=0
 *===========================================================================*/
    .code16
    .section .text
    .global _start

_start:
    /* 保存 DL（引导驱动器号）到段内变量，用 CS 前缀避开段寄存器初始化顺序问题 */
    movb    %dl, %cs:(s2_drive - _start)

    /* 规范化段寄存器，DS=0x1000 */
    movw    $0x1000, %ax
    movw    %ax, %ds
    movw    %ax, %es
    movw    %ax, %fs
    movw    %ax, %gs
    xorw    %ax, %ax
    movw    %ax, %ss
    movw    $0x7BFF, %sp

    /* 把驱动器号写入 BootInfo（DS=0 访问物理 0x5000）*/
    movb    s2_drive, %al           /* DS=0x1000，s2_drive 是段内偏移 */
    movw    $0, %bx
    movw    %bx, %ds
    movb    %al, (BOOT_INFO + BI_BOOT_DRV)
    movw    $0x1000, %bx
    movw    %bx, %ds

/*---------------------------------------------------------------------------
 * E820 内存探测
 *---------------------------------------------------------------------------*/
e820_probe:
    xorw    %ax, %ax
    movw    %ax, %es
    movw    $E820_BUF, %di          /* ES:DI = 0:0x6000 */
    xorl    %ebx, %ebx              /* continuation = 0 */
    xorl    %esi, %esi              /* 条目计数 */

.e820_loop:
    movl    $0xE820,     %eax
    movl    $0x534D4150, %edx       /* "SMAP" */
    movl    $24,         %ecx
    int     $0x15
    jc      .e820_done
    cmpl    $0x534D4150, %eax
    jne     .e820_done
    jecxz   .e820_next              /* length=0 跳过 */

    incl    %esi

    /* type=1（可用），累加 length 到 BootInfo.mem_total（DS=0）*/
    movw    $0, %ax
    movw    %ax, %ds
    movl    %es:16(%di), %eax
    cmpl    $1, %eax
    jne     .e820_restore_ds

    movl    %es:8(%di),  %eax
    movl    %es:12(%di), %edx
    addl    %eax, (BOOT_INFO + BI_MEM_TOTAL)
    adcl    %edx, (BOOT_INFO + BI_MEM_TOTAL + 4)

.e820_restore_ds:
    movw    $0x1000, %ax
    movw    %ax, %ds

.e820_next:
    addw    $24, %di
    testl   %ebx, %ebx
    jz      .e820_done
    cmpl    $128, %esi
    jge     .e820_done
    jmp     .e820_loop

.e820_done:
    /* 写 e820_count 和 e820_addr（DS=0）*/
    movw    $0, %ax
    movw    %ax, %ds
    movl    %esi, (BOOT_INFO + BI_E820_CNT)
    movl    $E820_BUF, (BOOT_INFO + BI_E820_ADDR)
    movw    $0x1000, %ax
    movw    %ax, %ds

/*---------------------------------------------------------------------------
 * VBE 图形模式（1680x1050 → 1440x900 → 800x600，32bpp）
 *---------------------------------------------------------------------------*/
vbe_setup:
    /* INT 10h/4F00h: 获取 VBE 控制器信息 */
    xorw    %ax, %ax
    movw    %ax, %es
    movw    %ax, %ds
    movl    $0x56424532, (VBE_INFO)     /* "VBE2" */
    movw    $0x1000, %ax
    movw    %ax, %ds

    movw    $VBE_INFO, %di
    movw    $0x4F00,   %ax
    int     $0x10
    cmpw    $0x004F, %ax
    jne     .vbe_skip

    /* 验证 "VESA" 签名 */
    xorw    %ax, %ax
    movw    %ax, %ds
    cmpl    $0x41534556, (VBE_INFO)
    movw    $0x1000, %ax
    movw    %ax, %ds
    jne     .vbe_skip

    /* 清候选模式 */
    movw    $0xFFFF, s2_m1680
    movw    $0xFFFF, s2_m1440
    movw    $0xFFFF, s2_m800

    /* 获取模式列表 FAR 指针: [VBE_INFO+14]=offset, [VBE_INFO+16]=segment */
    xorw    %ax, %ax
    movw    %ax, %ds
    movzwl  (VBE_INFO + 14), %esi
    movzwl  (VBE_INFO + 16), %ebx
    movw    $0x1000, %ax
    movw    %ax, %ds
    shll    $4, %ebx
    addl    %ebx, %esi              /* ESI = 模式列表物理地址 */

.vbe_scan:
    xorw    %ax, %ax
    movw    %ax, %ds
    movw    (%esi), %cx
    cmpw    $0xFFFF, %cx
    je      .vbe_select
    addl    $2, %esi
    pushl   %esi
    pushl   %ecx

    /* INT 10h/4F01h: 获取模式信息 */
    xorw    %ax, %ax
    movw    %ax, %es
    movw    $VBE_MODE, %di
    movw    $0x4F01,   %ax
    int     $0x10

    popl    %ecx
    movw    $0x1000, %bx
    movw    %bx, %ds
    cmpw    $0x004F, %ax
    jne     .vbe_scan_next

    /* Attr[bit0]=硬件支持, Attr[bit7]=LFB */
    movw    (VBE_MODE + MIB_ATTR), %ax
    andw    $0x0081, %ax
    cmpw    $0x0081, %ax
    jne     .vbe_scan_next

    /* MemModel=6 DirectColor */
    movb    (VBE_MODE + MIB_MODEL), %al
    cmpb    $6, %al
    jne     .vbe_scan_next

    /* BPP=32 */
    movb    (VBE_MODE + MIB_BPP), %al
    cmpb    $32, %al
    jne     .vbe_scan_next

    movw    (VBE_MODE + MIB_XRES), %ax
    movw    (VBE_MODE + MIB_YRES), %bx

    cmpw    $1680, %ax
    jne     .try1440
    cmpw    $1050, %bx
    jne     .try1440
    movw    %cx, s2_m1680
    jmp     .vbe_scan_next
.try1440:
    cmpw    $1440, %ax
    jne     .try800
    cmpw    $900, %bx
    jne     .try800
    movw    %cx, s2_m1440
    jmp     .vbe_scan_next
.try800:
    cmpw    $800, %ax
    jne     .vbe_scan_next
    cmpw    $600, %bx
    jne     .vbe_scan_next
    movw    %cx, s2_m800

.vbe_scan_next:
    popl    %esi
    xorw    %ax, %ax
    movw    %ax, %ds
    jmp     .vbe_scan

.vbe_select:
    movw    $0x1000, %ax
    movw    %ax, %ds

    movw    s2_m1680, %cx
    cmpw    $0xFFFF, %cx
    jne     .vbe_set
    movw    s2_m1440, %cx
    cmpw    $0xFFFF, %cx
    jne     .vbe_set
    movw    s2_m800, %cx
    cmpw    $0xFFFF, %cx
    jne     .vbe_set

.vbe_skip:
    jmp     rsdp_probe

.vbe_set:
    /* 重新查询该模式信息 */
    xorw    %ax, %ax
    movw    %ax, %es
    movw    $VBE_MODE, %di
    pushw   %cx
    movw    $0x4F01, %ax
    int     $0x10
    popw    %cx

    /* INT 10h/4F02h: 设置模式（bit14=LFB）*/
    movw    %cx, %bx
    orw     $0x4000, %bx
    movw    $0x4F02, %ax
    int     $0x10

    /* 写 LFB 参数到 BootInfo（DS=0）*/
    xorw    %ax, %ax
    movw    %ax, %ds
    movl    (VBE_MODE + MIB_BASE), %eax
    movl    %eax, (BOOT_INFO + BI_FB_ADDR)
    movl    $0,   (BOOT_INFO + BI_FB_ADDR + 4)

    movzwl  (VBE_MODE + MIB_PITCH), %eax
    movl    %eax, (BOOT_INFO + BI_FB_PITCH)

    movzwl  (VBE_MODE + MIB_XRES), %eax
    movl    %eax, (BOOT_INFO + BI_FB_WIDTH)

    movzwl  (VBE_MODE + MIB_YRES), %eax
    movl    %eax, (BOOT_INFO + BI_FB_HEIGHT)

    movb    $32,  (BOOT_INFO + BI_FB_BPP)

    movw    $0x1000, %ax
    movw    %ax, %ds

/*---------------------------------------------------------------------------
 * ACPI RSDP 探测（DS=0）
 *---------------------------------------------------------------------------*/
rsdp_probe:
    xorw    %ax, %ax
    movw    %ax, %ds

    /* 先搜 EBDA（BDA 0x040E = EBDA 段）*/
    movzwl  (0x040E), %esi
    shll    $4, %esi
    movl    %esi, %edi
    addl    $1024, %edi
    call    search_rsdp
    testl   %eax, %eax
    jnz     .rsdp_found

    /* 再搜 BIOS ROM 0xE0000–0xFFFFF */
    movl    $0xE0000,  %esi
    movl    $0x100000, %edi
    call    search_rsdp
    testl   %eax, %eax
    jnz     .rsdp_found

    movl    $0, (BOOT_INFO + BI_RSDP_ADDR)
    movl    $0, (BOOT_INFO + BI_RSDP_ADDR + 4)
    jmp     .rsdp_done

.rsdp_found:
    movl    %eax, (BOOT_INFO + BI_RSDP_ADDR)
    movl    $0,   (BOOT_INFO + BI_RSDP_ADDR + 4)

.rsdp_done:
    movl    $0xB007B007, (BOOT_INFO + BI_MAGIC)
    movl    $1,          (BOOT_INFO + BI_VERSION)

/*---------------------------------------------------------------------------
 * 进入 32 位保护模式
 *---------------------------------------------------------------------------*/
enter_pm:
    cli
    movw    $0x1000, %ax
    movw    %ax, %ds
    data32 lgdt gdt_ptr
    movl    %cr0, %eax
    orl     $1, %eax
    movl    %eax, %cr0
    ljmp    $0x08, $pm32_entry

/*---------------------------------------------------------------------------
 * search_rsdp — DS=0 时搜索 [ESI, EDI) 中的 "RSD PTR " 签名
 * 返回: EAX = 物理地址，未找到则 EAX=0
 *---------------------------------------------------------------------------*/
search_rsdp:
    xorw    %ax, %ax
    movw    %ax, %ds
.sr_loop:
    cmpl    %edi, %esi
    jge     .sr_fail
    cmpl    $0x20445352, (%esi)     /* "RSD " */
    jne     .sr_next
    cmpl    $0x20525450, 4(%esi)    /* "PTR " */
    jne     .sr_next
    /* checksum: 前 20 字节之和 mod 256 = 0 */
    xorl    %eax, %eax
    xorl    %ebx, %ebx
.sr_ck:
    movzbl  (%esi,%ebx,1), %ecx
    addl    %ecx, %eax
    incl    %ebx
    cmpl    $20, %ebx
    jl      .sr_ck
    testb   %al, %al
    jnz     .sr_next
    movl    %esi, %eax
    ret
.sr_next:
    addl    $16, %esi
    jmp     .sr_loop
.sr_fail:
    xorl    %eax, %eax
    ret

/*---------------------------------------------------------------------------
 * 段内数据（DS=0x1000 时访问）
 *---------------------------------------------------------------------------*/
s2_drive: .byte 0x80
s2_m1680: .word 0xFFFF
s2_m1440: .word 0xFFFF
s2_m800:  .word 0xFFFF

/*---------------------------------------------------------------------------
 * GDT（5 个描述符：NULL / 32代码 / 32数据 / 64代码 / 64数据）
 *---------------------------------------------------------------------------*/
    .align 8
gdt_start:
    .quad 0                         /* NULL */
    .word 0xFFFF, 0x0000            /* 32-bit code  CS=0x08 */
    .byte 0x00, 0x9A, 0xCF, 0x00
    .word 0xFFFF, 0x0000            /* 32-bit data  DS=0x10 */
    .byte 0x00, 0x92, 0xCF, 0x00
    .word 0x0000, 0x0000            /* 64-bit code  CS=0x18, L=1 */
    .byte 0x00, 0x9A, 0xA0, 0x00
    .word 0xFFFF, 0x0000            /* 64-bit data  DS=0x20 */
    .byte 0x00, 0x92, 0xCF, 0x00
gdt_end:

gdt_ptr:
    .word   gdt_end - gdt_start - 1
    .long   gdt_start + 0x10000     /* 物理地址 */

    .align 4
jump64_target:
    .long   KENTRY                  /* 偏移 = 0x100000 */
    .word   0x18                    /* 64-bit code segment */

/*===========================================================================
 * 32 位保护模式
 *===========================================================================*/
    .code32

pm32_entry:
    movw    $0x10, %ax
    movw    %ax, %ds
    movw    %ax, %es
    movw    %ax, %ss
    movw    %ax, %fs
    movw    %ax, %gs
    movl    $0x7BFF, %esp

    /*-----------------------------------------------------------
     * CPUID: 确认 Long Mode 可用
     *-----------------------------------------------------------*/
    movl    $0x80000000, %eax
    cpuid
    cmpl    $0x80000001, %eax
    jb      no_longmode
    movl    $0x80000001, %eax
    cpuid
    testl   $(1 << 29), %edx
    jz      no_longmode

    /*-----------------------------------------------------------
     * PIO ATA LBA28：将内核从磁盘加载到 0x100000
     *
     * Primary ATA（端口 0x1F0–0x1F7），端口号 > 0xFF 须用 %dx
     *   0x1F0  data (16-bit)
     *   0x1F2  sector count
     *   0x1F3  LBA[7:0]
     *   0x1F4  LBA[15:8]
     *   0x1F5  LBA[23:16]
     *   0x1F6  0xE0 | LBA[27:24]  (Master, LBA mode)
     *   0x1F7  command / status
     *
     * EBX = 当前 LBA
     * ESI = 剩余扇区数
     * EDI = 目标写地址
     *-----------------------------------------------------------*/
    movl    $KERNEL_LBA,     %ebx
    movl    $KERNEL_SECTORS, %esi
    movl    $KENTRY,         %edi

.ata_loop:
    testl   %esi, %esi
    jz      .ata_done

    /* 等待 BSY=0 */
    movw    $0x1F7, %dx
.ata_bsy:
    inb     %dx, %al
    testb   $0x80, %al
    jnz     .ata_bsy

    /* 写扇区数 = 1 */
    movw    $0x1F2, %dx
    movb    $1, %al
    outb    %al, %dx

    /* LBA[7:0] */
    movw    $0x1F3, %dx
    movl    %ebx, %eax
    outb    %al, %dx

    /* LBA[15:8] */
    movw    $0x1F4, %dx
    movl    %ebx, %eax
    shrl    $8, %eax
    outb    %al, %dx

    /* LBA[23:16] */
    movw    $0x1F5, %dx
    movl    %ebx, %eax
    shrl    $16, %eax
    outb    %al, %dx

    /* Drive/Head: 0xE0 | LBA[27:24]，Master, LBA */
    movw    $0x1F6, %dx
    movl    %ebx, %eax
    shrl    $24, %eax
    andb    $0x0F, %al
    orb     $0xE0, %al
    outb    %al, %dx

    /* READ SECTORS 命令 */
    movw    $0x1F7, %dx
    movb    $0x20, %al
    outb    %al, %dx

    /* 等待 BSY=0 且 DRQ=1 */
.ata_drq:
    inb     %dx, %al
    testb   $0x80, %al
    jnz     .ata_drq
    testb   $0x08, %al
    jz      .ata_drq

    /* 从数据端口读 256 words（512 字节）→ ES:EDI */
    movw    $0x1F0, %dx
    movl    $256,   %ecx
    rep insw                    /* ES:EDI 自增，ECX→0 */

    incl    %ebx
    decl    %esi
    jmp     .ata_loop

.ata_done:

    /*-----------------------------------------------------------
     * 构建 4 级页表（Identity Map 前 4GB，2MB 大页）
     * PML4 @ 0x400000  PDPT @ 0x401000  PD[0-3] @ 0x402000-0x405FFF
     *-----------------------------------------------------------*/
    /* 清零 6 页（24 KB）*/
    movl    $PML4_BASE,       %edi
    movl    $(6 * 4096 / 4),  %ecx
    xorl    %eax, %eax
    rep stosl

    /* PML4[0] → PDPT */
    movl    $(0x401000 | 3), 0x400000
    movl    $0,              0x400004

    /* PDPT[0..3] → PD[0..3] */
    movl    $(0x402000 | 3), 0x401000
    movl    $0,              0x401004
    movl    $(0x403000 | 3), 0x401008
    movl    $0,              0x40100C
    movl    $(0x404000 | 3), 0x401010
    movl    $0,              0x401014
    movl    $(0x405000 | 3), 0x401018
    movl    $0,              0x40101C

    /* 填充 PD[k][j] = (k<<30)|(j<<21) | 0x83 */
    xorl    %ebx, %ebx          /* k */
.pt_gb:
    xorl    %ecx, %ecx          /* j */
    movl    $0x402000, %edi
    movl    %ebx, %eax
    shll    $12, %eax
    addl    %eax, %edi          /* PD[k] 起始 */
.pt_2m:
    movl    %ebx, %eax
    shll    $30, %eax
    movl    %ecx, %edx
    shll    $21, %edx
    addl    %edx, %eax
    orl     $0x83, %eax
    movl    %eax, (%edi)
    movl    $0,   4(%edi)
    addl    $8, %edi
    incl    %ecx
    cmpl    $512, %ecx
    jl      .pt_2m
    incl    %ebx
    cmpl    $4, %ebx
    jl      .pt_gb

    /*-----------------------------------------------------------
     * 进入 64 位长模式
     *-----------------------------------------------------------*/
    /* CR4.PAE */
    movl    %cr4, %eax
    orl     $(1 << 5), %eax
    movl    %eax, %cr4

    /* CR3 = PML4 */
    movl    $PML4_BASE, %eax
    movl    %eax, %cr3

    /* EFER.LME */
    movl    $0xC0000080, %ecx
    rdmsr
    orl     $(1 << 8), %eax
    wrmsr

    /* CR0.PG | CR0.PE */
    movl    %cr0, %eax
    orl     $0x80000001, %eax
    movl    %eax, %cr0

    /* 远跳到 64 位代码段 */
    ljmpl   *(jump64_target + 0x10000)

no_longmode:
    /* 向 VGA 文本模式写 '!' 表示错误 */
    movw    $0xB800, %ax
    movw    %ax, %es
    movb    $'!', %es:0
    movb    $0x4F, %es:1
.halt32:
    hlt
    jmp     .halt32
